@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject MyWebApp.Services.CartService CartService
@rendermode InteractiveServer
@implements IDisposable

<a href="/cart" class="text-dark text-decoration-none me-4 position-relative" title="Корзина">
    <i class="bi bi-cart3 fs-4"></i>
    @if (itemCount > 0)
    {
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">
            @itemCount
        </span>
    }
</a>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private int itemCount = 0;
    private string? userName;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            userName = authState.User.Identity?.Name;
            itemCount = CartService.GetTotalCount(userName);
        }
        
        CartService.OnChange += UpdateBadge;
    }

    private void UpdateBadge()
    {
        itemCount = CartService.GetTotalCount(userName);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CartService.OnChange -= UpdateBadge;
    }
}