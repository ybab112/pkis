@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing

<div class="nav-scrollable">
    <nav class="flex-column">
        
        <div class="nav-item px-3 mt-2">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-house-door me-2" aria-hidden="true"></i> Главная
            </NavLink>
        </div>
        
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/shoes">
                <i class="bi bi-box-seam me-2" aria-hidden="true"></i> Каталог обуви
            </NavLink>
        </div>
        
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/news">
                <i class="bi bi-newspaper me-2" aria-hidden="true"></i> Новости
            </NavLink>
        </div>

        <AuthorizeView Roles="Системный администратор, Администратор">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/analytics">
                    <i class="bi bi-graph-up-arrow me-2" aria-hidden="true"></i> Админ: Отчеты
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/users">
                    <i class="bi bi-people me-2" aria-hidden="true"></i> Админ: Пользователи
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Roles="Системный администратор, Администратор, Менеджер">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="manager/products">
                    <i class="bi bi-tags-fill me-2" aria-hidden="true"></i> Менеджер: Товары
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="manager/orders">
                    <i class="bi bi-receipt me-2" aria-hidden="true"></i> Менеджер: Заказы
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 mt-4">
                    <NavLink class="nav-link" href="/cart">
                        <i class="bi bi-cart3 me-2" aria-hidden="true"></i> Моя корзина
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

    </nav>
</div>