@page "/cart"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@attribute [Authorize]
@rendermode InteractiveServer
@inject MyWebApp.Services.CartService CartService
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>Моя корзина</PageTitle>

<h2 class="mb-4"><i class="bi bi-cart3"></i> Ваша корзина</h2>

<AuthorizeView Context="authState">
    <Authorized>
        @{
            var userName = authState.User.Identity?.Name;
            var userCart = CartService.GetItems(userName);
        }

        @if (userCart == null || userCart.Count == 0)
        {
            <div class="alert alert-info">
                Ваша корзина пуста. <a href="/shoes" class="alert-link">Перейти в каталог</a>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-lg-8">
                    @foreach (var item in userCart)
                    {
                        <div class="card shadow-sm border-0 mb-3">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <img src="@item.Shoe.ImagePath" alt="@item.Shoe.Name" class="rounded" style="width: 80px; height: 80px; object-fit: cover;">
                                    
                                    <div class="ms-3 flex-grow-1">
                                        <h5 class="mb-1">@item.Shoe.Name</h5>
                                        <div class="d-flex align-items-center text-muted small">
                                            <span>Размер:</span>
                                            <select class="form-select form-select-sm ms-2" style="width: 75px;"
                                                    value="@item.Size" 
                                                    @onchange="(e) => UpdateItemSize(userName, item.Shoe.Id, e)">
                                                @for (int size = 36; size <= 46; size++)
                                                {
                                                    <option value="@size">@size</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    
                                    <div class="me-4 d-flex align-items-center">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CartService.DecreaseQuantity(userName, item.Shoe.Id)">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <span class="mx-3 fw-bold">@item.Quantity</span>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CartService.IncreaseQuantity(userName, item.Shoe.Id)">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                    
                                    <div class="fw-bold me-4">
                                        @((item.Shoe.Price * item.Quantity).ToString("N0")) ₽
                                    </div>
                                
                                    <button class="btn btn-outline-danger" @onclick="() => CartService.RemoveFromCart(userName, item.Shoe.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 bg-light p-3">
                        <h5>Итого: <span class="text-primary">@CartService.GetTotalPrice(userName).ToString("N0") ₽</span></h5>
                        <button class="btn btn-primary w-100 mt-3" @onclick="GoToCheckout">
                            Оформить заказ
                        </button>
                    </div>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    protected override void OnInitialized()
    {
        CartService.OnChange += RefreshState;
    }

    private void UpdateItemSize(string? userName, int shoeId, ChangeEventArgs e)
    {
        if (string.IsNullOrEmpty(userName)) return;

        if (int.TryParse(e.Value?.ToString(), out var newSize))
        {
            CartService.UpdateSize(userName, shoeId, newSize);
        }
    }

    private void RefreshState()
    {
        InvokeAsync(StateHasChanged);
    }

    private void GoToCheckout()
    {
        NavigationManager.NavigateTo("/checkout");
    }

    public void Dispose()
    {
        CartService.OnChange -= RefreshState;
    }
}