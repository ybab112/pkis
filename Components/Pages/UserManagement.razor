@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@attribute [Authorize(Roles = "Системный администратор, Администратор")]

@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using Microsoft.AspNetCore.Identity
@inject IServiceScopeFactory ScopeFactory

<h2 class="mb-4">Управление пользователями</h2>


@if (!string.IsNullOrEmpty(pageError))
{
    <div class="alert alert-danger shadow-sm">
        <i class="bi bi-exclamation-triangle"></i> КРИТИЧЕСКАЯ ОШИБКА: @pageError
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">
        <h5 class="card-title m-0">Список учетных записей</h5>
        <button type="button" class="btn btn-success" @onclick="OpenAddModal">
            <i class="bi bi-person-plus"></i> Добавить пользователя
        </button>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Email / Логин</th>
                        <th>Роль</th>
                        <th class="text-end pe-4">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (usersList.Count == 0 && string.IsNullOrEmpty(pageError))
                    {
                        <tr><td colspan="3" class="text-center py-4">Загрузка пользователей...</td></tr>
                    }
                    else
                    {
                        @foreach (var userDto in usersList)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@userDto.User.Email</td>
                                <td>
                                    @if (userDto.CurrentRole == "Системный администратор")
                                    {
                                        <span class="badge bg-danger">@userDto.CurrentRole</span>
                                    }
                                    else if (userDto.CurrentRole == "Администратор")
                                    {
                                        <span class="badge bg-warning text-dark">@userDto.CurrentRole</span>
                                    }
                                    else if (userDto.CurrentRole == "Менеджер")
                                    {
                                        <span class="badge bg-primary">@userDto.CurrentRole</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@userDto.CurrentRole</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button type="button" class="btn btn-outline-primary btn-sm me-2" @onclick="() => OpenEditModal(userDto)">
                                        <i class="bi bi-pencil"></i> Изменить
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => DeleteUser(userDto.User)">
                                        <i class="bi bi-trash"></i> Удалить
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (isModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(isEditMode ? "Изменение роли" : "Новый пользователь")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2">@modalError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Email (Логин)</label>
                        <input type="email" class="form-control" @bind="currentUserEmail" disabled="@isEditMode" placeholder="name@example.com" />
                    </div>

                    @if (!isEditMode)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Пароль</label>
                            <input type="password" class="form-control" @bind="currentPassword" placeholder="Введите надежный пароль" />
                        </div>
                    }

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small">Назначить роль</label>
                        <select class="form-select" @bind="currentRole">
                            <option value="Пользователь">Пользователь</option>
                            <option value="Менеджер">Менеджер</option>
                            <option value="Администратор">Администратор</option>
                            <option value="Системный администратор">Системный администратор</option>
                        </select>
                    </div>

                </div>
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-secondary px-4" @onclick="CloseModal">Отмена</button>
                    <button type="button" class="btn btn-primary px-4" @onclick="SaveUser">Сохранить</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UserRoleViewModel> usersList = new();
    private string pageError = "";

    private bool isModalOpen = false;
    private bool isEditMode = false;
    private string modalError = "";

    private string currentUserId = "";
    private string currentUserEmail = "";
    private string currentPassword = "";
    private string currentRole = "Пользователь";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            usersList.Clear();
            using var scope = ScopeFactory.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<IdentityUser>>();

            var users = await userManager.Users.ToListAsync();
            
            foreach (var user in users)
            {
                var roles = await userManager.GetRolesAsync(user);
                usersList.Add(new UserRoleViewModel
                {
                    User = user,
                    CurrentRole = roles.FirstOrDefault() ?? "Пользователь"
                });
            }
            pageError = ""; 
        }
        catch (Exception ex)
        {
            pageError = ex.Message;
        }
    }

    private async Task OpenAddModal()
    {
        isEditMode = false;
        currentUserId = "";
        currentUserEmail = "";
        currentPassword = "";
        currentRole = "Пользователь";
        modalError = "";
        isModalOpen = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task OpenEditModal(UserRoleViewModel userDto)
    {
        isEditMode = true;
        currentUserId = userDto.User.Id;
        currentUserEmail = userDto.User.Email ?? "";
        currentPassword = ""; 
        currentRole = userDto.CurrentRole;
        modalError = "";
        isModalOpen = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        StateHasChanged();
    }

    private async Task SaveUser()
    {
        modalError = "";
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<IdentityUser>>();
            var roleManager = scope.ServiceProvider.GetRequiredService<RoleManager<IdentityRole>>();

            if (!await roleManager.RoleExistsAsync(currentRole))
            {
                modalError = $"Роль '{currentRole}' не найдена в базе данных.";
                return;
            }

            if (isEditMode)
            {
                var user = await userManager.FindByIdAsync(currentUserId);
                if (user != null)
                {
                    var currentRoles = await userManager.GetRolesAsync(user);
                    await userManager.RemoveFromRolesAsync(user, currentRoles);
                    await userManager.AddToRoleAsync(user, currentRole);
                    
                    CloseModal();
                    await LoadUsers();
                }
            }
            else
            {
                if (string.IsNullOrWhiteSpace(currentUserEmail) || string.IsNullOrWhiteSpace(currentPassword))
                {
                    modalError = "Email и Пароль обязательны.";
                    return;
                }

                var identityUser = new IdentityUser { UserName = currentUserEmail, Email = currentUserEmail, EmailConfirmed = true };
                var result = await userManager.CreateAsync(identityUser, currentPassword);

                if (result.Succeeded)
                {
                    await userManager.AddToRoleAsync(identityUser, currentRole);
                    CloseModal();
                    await LoadUsers();
                }
                else
                {
                    modalError = string.Join(" ", result.Errors.Select(e => e.Description));
                }
            }
        }
        catch (Exception ex)
        {
            modalError = "Ошибка: " + ex.Message;
        }
    }

    private async Task DeleteUser(IdentityUser user)
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<IdentityUser>>();

            await userManager.DeleteAsync(user);
            await LoadUsers();
        }
        catch (Exception ex)
        {
            pageError = "Не удалось удалить пользователя: " + ex.Message;
        }
    }

    public class UserRoleViewModel
    {
        public IdentityUser User { get; set; } = null!;
        public string CurrentRole { get; set; } = "";
    }
}